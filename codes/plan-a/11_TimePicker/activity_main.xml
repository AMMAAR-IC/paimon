<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="20dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Time Picker Example" android:textSize="24sp" android:textStyle="bold"
        android:gravity="center" android:layout_marginBottom="20dp"/>

    <Button android:id="@+id/btnPickTime"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Select Time"/>

    <TextView android:id="@+id/tvTime"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Selected Time: " android:textSize="20sp" android:layout_marginTop="20dp"/>
</LinearLayout>
